{
  "name": "leave-management-node-react",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "client"
  ],
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm --workspace client run dev\"",
    "server": "nodemon server.js",
    "client": "npm --workspace client run dev",
    "build": "cd client && npm run build && cd .. && node scripts/copy-dist.js",
    "start": "node server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "nodemon": "^3.0.1"
  }
}
